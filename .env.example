NODE_ENV=production
HOST=0.0.0.0
PORT=8787

# PostgreSQL em producao. Se vazio, o app usa SQLite local.
DATABASE_URL=postgres://mesapro:mesapro_password@postgres:5432/mesapro
PGSSL=false
PG_POOL_MAX=10

# Segurança e CORS.
SESSION_TTL_MS=43200000
CORS_ORIGIN=https://app.seudominio.com
FORCE_HTTPS=true
ALLOWED_HOSTS=app.seudominio.com
METRICS_TOKEN=troque_este_token
METRICS_PUBLIC=false

# HTTPS direto no Node. Em producao prefira proxy reverso como Caddy/Nginx.
HTTPS_KEY_PATH=
HTTPS_CERT_PATH=

# Backups automaticos. 1440 = uma vez por dia.
BACKUP_INTERVAL_MINUTES=1440
BACKUP_DIR=/app/backups
BACKUP_RETENTION_DAYS=30
BACKUP_ENCRYPTION_KEY=
BACKUP_ALERT_WEBHOOK=

# SQLite fallback local.
DB_PATH=/app/data/mesa-pro.sqlite

# Primeiro acesso. Defina estes valores antes da primeira inicializacao do banco.
RESTAURANT_ID=restaurant-main
RESTAURANT_NAME=Nome do Restaurante
RESTAURANT_SLUG=principal
VITE_RESTAURANT_SLUG=principal
INITIAL_ADMIN_ID=admin-main
INITIAL_ADMIN_NAME=Administrador
INITIAL_ADMIN_PIN=troque_este_pin
